{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/boot.sh",
            "statusMessage": "Loading Vibeboss HQ boot brief"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/boot.sh",
            "statusMessage": "Loading Vibeboss HQ boot brief"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/boot.sh",
            "statusMessage": "Loading Vibeboss HQ boot brief"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/compact-boot.sh",
            "statusMessage": "Loading Vibeboss compact handover"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/pre-compact.sh",
            "statusMessage": "Writing Vibeboss rolling handover"
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/pre-compact.sh",
            "statusMessage": "Writing Vibeboss rolling handover"
          }
        ]
      }
    ]
  }
}
