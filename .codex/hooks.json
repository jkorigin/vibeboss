{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/route.sh\"",
            "statusMessage": "Loading Vibeboss framework context"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/route.sh\"",
            "statusMessage": "Loading Vibeboss framework context"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/route.sh\"",
            "statusMessage": "Loading Vibeboss framework context"
          }
        ]
      }
    ]
  }
}
